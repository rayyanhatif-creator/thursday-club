<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>أرشيف الذكريات</title>
    <style>
        body { background: #0f0f12; color: #fff; text-align: center; font-family: sans-serif; padding: 20px; }
        .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-width: 500px; margin: auto; }
        .box { aspect-ratio: 1/1; overflow: hidden; border-radius: 10px; border: 2px solid #333; }
        .box img { width: 100%; height: 100%; object-fit: cover; }
    </style>
</head>
<body>
    <h1 style="color: #f1c40f;">📸 أرشيف الذكريات</h1>
    <div class="grid">
        <div class="box"><img src="images/1.jpg" alt="صورة"></div>
        <div class="box"><img src="images/2.jpg" alt="صورة"></div>
        <div class="box"><img src="images/3.jpg" alt="صورة"></div>
        <div class="box"><img src="images/4.jpg" alt="صورة"></div>
        <div class="box"><img src="images/5.jpg" alt="صورة"></div>
        <div class="box"><img src="images/6.jpg" alt="صورة"></div>
        <div class="box"><img src="images/7.jpg" alt="صورة"></div>
        <div class="box"><img src="images/8.jpg" alt="صورة"></div>
        <div class="box"><img src="images/9.jpg" alt="صورة"></div>
        <div class="box"><img src="images/10.jpg" alt="صورة"></div>
    </div>
    <br><a href="index.html" style="color:white;">← الرئيسية</a>
</body>
</html>
